# Frontend environment variables.
#
# These are BAKED INTO THE BUNDLE at build time by Vite — they're public.
# In local dev you don't need any of them (the Vite proxy in vite.config.ts
# handles /api, /socket.io, and /uploads). In Render production they're set
# from render.yaml and point at the deployed backend.

# URL of the backend REST API (includes the /api/v2 suffix)
VITE_API_BASE_URL=https://zillit-catering-api.onrender.com/api/v2

# WebSocket base URL (backend origin, no trailing slash, no /api suffix)
VITE_WS_BASE_URL=https://zillit-catering-api.onrender.com
